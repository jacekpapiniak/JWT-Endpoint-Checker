meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: http://localhost:5250/api/login
  body: json
  auth: inherit
}

body:json {
  {
    "Email" : "{{email}}",
    "Password" : "{{password}}"
  }
}

script:post-response {
  const body = res.getBody();
  
  // JSON jwtToken
  const token = body.jwtToken;
  
  // set the token env variable
  bru.setEnvVar("token", token);
}

settings {
  encodeUrl: true
  timeout: 0
}
